<Window x:Class="LibrarySystem.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Reports - F5" Height="600" Width="800" WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="LIBRARY SYSTEM SUMMARY REPORT" FontSize="24" FontWeight="Bold" Foreground="#FF1A2A6C" HorizontalAlignment="Center" Margin="0,0,0,20"/>

		<UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">
			<Border Background="#E3F2FD" Margin="5" Padding="15" CornerRadius="10" BorderBrush="#2196F3" BorderThickness="1">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock Text="Total Books" FontSize="14" Foreground="#1976D2"/>
					<TextBlock x:Name="lblTotalBooks" Text="540" FontSize="28" FontWeight="Bold" Foreground="#0D47A1"/>
				</StackPanel>
			</Border>

			<Border Background="#FFF3E0" Margin="5" Padding="15" CornerRadius="10" BorderBrush="#FF9800" BorderThickness="1">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock Text="Books Issued" FontSize="14" Foreground="#F57C00"/>
					<TextBlock x:Name="lblIssuedBooks" Text="42" FontSize="28" FontWeight="Bold" Foreground="#E65100"/>
				</StackPanel>
			</Border>

			<Border Background="#FFEBEE" Margin="5" Padding="15" CornerRadius="10" BorderBrush="#F44336" BorderThickness="1">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock Text="Total Fine (Rs)" FontSize="14" Foreground="#D32F2F"/>
					<TextBlock x:Name="lblTotalFine" Text="1250" FontSize="28" FontWeight="Bold" Foreground="#B71C1C"/>
				</StackPanel>
			</Border>
		</UniformGrid>

		<GroupBox Grid.Row="2" Header="Overdue Books (Action Required)" Margin="0,10" Foreground="Red" FontWeight="Bold">
			<DataGrid x:Name="dgOverdue" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="5">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Borrower Name" Binding="{Binding Name}" Width="*"/>
					<DataGridTextColumn Header="Book Title" Binding="{Binding Book}" Width="*"/>
					<DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat=d}" Width="120"/>
					<DataGridTextColumn Header="Days Overdue" Binding="{Binding DaysLate}" Width="100"/>
				</DataGrid.Columns>
			</DataGrid>
		</GroupBox>

		<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
			<Button Content="Print Report" Click="BtnPrint_Click" Width="150" Height="40" Background="#FF1A2A6C" Foreground="White" FontWeight="Bold"/>
		</StackPanel>
	</Grid>
</Window>