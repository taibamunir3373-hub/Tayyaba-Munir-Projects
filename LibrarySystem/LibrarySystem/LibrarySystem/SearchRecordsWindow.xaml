<Window x:Class="LibrarySystem.SearchRecordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Library Catalog - F6" Height="600" Width="850" WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="SEARCH BOOK RECORDS" FontSize="22" FontWeight="Bold" Foreground="#FF1A2A6C" HorizontalAlignment="Center" Margin="0,0,0,20"/>

		<Border Grid.Row="1" Background="#F0F2F5" CornerRadius="8" Padding="15" Margin="0,0,0,20">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="🔍" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
				<StackPanel>
					<TextBlock Text="Enter Book Title, Author, or Book ID:" FontSize="11" Foreground="DimGray"/>
					<TextBox x:Name="txtSearchGlobal" Width="500" Height="35" VerticalContentAlignment="Center" 
                             FontSize="14" Padding="10,0" TextChanged="txtSearchGlobal_TextChanged"/>
				</StackPanel>
				<Button Content="Clear Search" Click="BtnClearSearch_Click" Margin="20,15,0,0" Width="100" Height="30" Background="White"/>
			</StackPanel>
		</Border>

		<DataGrid Grid.Row="2" x:Name="dgSearchResults" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                  AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DDDDDD">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Book ID" Binding="{Binding BookID}" Width="100"/>
				<DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
				<DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="*"/>
				<DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="150"/>
				<DataGridTextColumn Header="Available Qty" Binding="{Binding Quantity}" Width="100"/>
			</DataGrid.Columns>
		</DataGrid>

		<TextBlock Grid.Row="3" x:Name="lblStatus" Text="Found 0 items" Margin="0,10,0,0" Foreground="Gray" FontWeight="SemiBold"/>
	</Grid>
</Window>