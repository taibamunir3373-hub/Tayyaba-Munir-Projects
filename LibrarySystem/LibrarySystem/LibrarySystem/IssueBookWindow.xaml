<Window x:Class="LibrarySystem.IssueBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Issue Book Module - F3" Height="700" Width="550" WindowStartupLocation="CenterScreen">

	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="ISSUE BOOK PANEL" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FF1A2A6C" Margin="0,0,0,20"/>

			<GroupBox Header="Step 1: Select Book" Margin="0,0,0,15" Padding="10">
				<StackPanel>
					<ComboBox x:Name="cmbBooks" Height="30" DisplayMemberPath="Title" SelectionChanged="cmbBooks_SelectionChanged"/>
					<TextBlock x:Name="lblBookInfo" Text="Select a book to see ID" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
				</StackPanel>
			</GroupBox>

			<GroupBox Header="Step 2: Issue To?" Margin="0,0,0,10" Padding="10">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<RadioButton x:Name="rbStudent" Content="Student" IsChecked="True" Checked="Type_Checked" Margin="0,0,30,0" FontWeight="Bold"/>
					<RadioButton x:Name="rbEmployee" Content="Employee (Teacher/HOD)" Checked="Type_Checked" FontWeight="Bold"/>
				</StackPanel>
			</GroupBox>

			<GroupBox x:Name="gbStudent" Header="Student Details" Margin="0,0,0,10" Padding="10">
				<StackPanel>
					<ComboBox x:Name="cmbStudents" Height="30" DisplayMemberPath="StuName" SelectionChanged="cmbStudents_SelectionChanged"/>
					<TextBlock x:Name="lblStuDetails" Text="Roll No: --- | Session: ---" Margin="0,5,0,0" Foreground="#FF1A2A6C"/>
				</StackPanel>
			</GroupBox>

			<GroupBox x:Name="gbEmployee" Header="Employee Details" Margin="0,0,0,10" Padding="10" IsEnabled="False" Opacity="0.5">
				<StackPanel>
					<ComboBox x:Name="cmbEmployees" Height="30" DisplayMemberPath="EmpName" SelectionChanged="cmbEmployees_SelectionChanged"/>
					<TextBlock x:Name="lblEmpDetails" Text="ID: --- | Designation: ---" Margin="0,5,0,0" Foreground="#FFB21F1F"/>
				</StackPanel>
			</GroupBox>

			<TextBlock Text="Return Date:" FontWeight="Bold" Margin="0,5,0,5"/>
			<DatePicker x:Name="dtpReturnDate" Height="35"/>

			<Button Content="CONFIRM ISSUE" Click="BtnConfirmIssue_Click" Height="45" Margin="0,20,0,0" Background="#FF1A2A6C" Foreground="White" FontWeight="Bold"/>
		</StackPanel>
	</Grid>
</Window>