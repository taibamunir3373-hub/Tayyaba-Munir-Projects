<Window x:Class="LibrarySystem.EditDeleteBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit or Delete Books - F2" Height="550" Width="750" WindowStartupLocation="CenterScreen">
	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="EDIT / DELETE BOOK RECORDS" FontSize="20" FontWeight="Bold" Foreground="#FF1A2A6C" HorizontalAlignment="Center" Margin="0,0,0,15"/>

		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
			<StackPanel Margin="5,0">
				<TextBlock Text="Book Title:" FontWeight="SemiBold" Margin="0,0,0,3"/>
				<TextBox x:Name="txtEditTitle" Width="180" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
			</StackPanel>

			<StackPanel Margin="5,0">
				<TextBlock Text="Author Name:" FontWeight="SemiBold" Margin="0,0,0,3"/>
				<TextBox x:Name="txtEditAuthor" Width="180" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
			</StackPanel>

			<StackPanel Margin="5,0">
				<TextBlock Text="Qty:" FontWeight="SemiBold" Margin="0,0,0,3"/>
				<TextBox x:Name="txtEditQty" Width="70" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
			</StackPanel>
		</StackPanel>

		<DataGrid Grid.Row="2" x:Name="dgBooks" AutoGenerateColumns="False" CanUserAddRows="False" 
                  SelectionChanged="dgBooks_SelectionChanged" IsReadOnly="True" AlternatingRowBackground="#F9F9F9" BorderBrush="LightGray" BorderThickness="1">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Book Title" Binding="{Binding Title}" Width="*"/>
				<DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="*"/>
				<DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
			</DataGrid.Columns>
		</DataGrid>

		<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
			<Button Content="Update Changes" Click="BtnUpdate_Click" Width="130" Height="35" Background="#FF1A2A6C" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
			<Button Content="Delete Record" Click="BtnDelete_Click" Width="130" Height="35" Background="#FFB21F1F" Foreground="White" FontWeight="Bold"/>
		</StackPanel>
	</Grid>
</Window>