<Window x:Class="LibrarySystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library System Login" Height="379" Width="400" WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<StackPanel VerticalAlignment="Center">
			<TextBlock Text="Library Login" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

			<TextBlock Text="Username:"/>
			<TextBox x:Name="txtUsername" Margin="0,5,0,15" Height="25"/>

			<TextBlock Text="Password:"/>
			<PasswordBox x:Name="txtPassword" Margin="0,5,0,15" Height="25"/>

			<TextBlock Text="Login As:"/>
			<ComboBox x:Name="cmbRole" Margin="0,5,0,20" Height="25">
				<ComboBoxItem Content="Librarian"/>
				<ComboBoxItem Content="Assistant"/>
			</ComboBox>

			<Button Content="Login" Click="BtnLogin_Click" Height="30" Background="#FF2196F3" Foreground="White"/>
		</StackPanel>
	</Grid>
</Window>