<Window x:Class="LibrarySystem.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Backup - F10" Height="350" Width="500" WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<StackPanel VerticalAlignment="Center">
			<TextBlock Text="DATABASE BACKUP &amp; RESTORE" FontSize="20" FontWeight="Bold" Foreground="#FF1A2A6C" HorizontalAlignment="Center" Margin="0,0,0,20"/>

			<Image Source="https://cdn-icons-png.flaticon.com/512/2859/2859652.png" Height="80" Margin="0,0,0,20"/>

			<TextBlock Text="Create a manual backup of your library records to prevent data loss." 
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="Gray" Margin="0,0,0,20"/>

			<Button Content="CREATE BACKUP NOW (.BAK)" Click="BtnBackup_Click" Height="45" Width="250" 
                    Background="#FF1A2A6C" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

			<TextBlock x:Name="lblLastBackup" Text="Last Backup: Never" HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="11" Foreground="DimGray"/>
		</StackPanel>
	</Grid>
</Window>