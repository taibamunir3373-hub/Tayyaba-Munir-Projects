<Window x:Class="LibrarySystem.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Book" Height="450" Width="400" WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="Add New Book" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

			<TextBlock Text="Book Title:"/>
			<TextBox x:Name="txtTitle" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

			<TextBlock Text="Author Name:"/>
			<TextBox x:Name="txtAuthor" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

			<TextBlock Text="Publisher:"/>
			<TextBox x:Name="txtPublisher" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

			<TextBlock Text="Quantity:"/>
			<TextBox x:Name="txtQuantity" Margin="0,5,0,25" Height="30" VerticalContentAlignment="Center" PreviewTextInput="NumberValidationTextBox"/>

			<Button Content="Save Book" Click="BtnSave_Click" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
			<Button Content="Clear Fields" Click="BtnClear_Click" Margin="0,10,0,0" Height="30" Background="#F44336" Foreground="White"/>
		</StackPanel>
	</Grid>
</Window>