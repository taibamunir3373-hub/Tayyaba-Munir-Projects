<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold"><i class="bi bi-person-circle me-2"></i>My Profile</h3>
  <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card p-4 text-center">
      <div style="width:100px;height:100px;background:linear-gradient(135deg,#0d6efd,#0dcaf0);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:2.5rem;color:white">
        <i class="bi bi-person-fill"></i>
      </div>
      <h4 class="fw-bold"><%= user.name %></h4>
      <span class="badge bg-primary mb-3"><%= user.role %></span>
      <hr>
      <a href="/auth/change-password" class="btn btn-outline-primary w-100">
        <i class="bi bi-key me-2"></i>Change Password
      </a>
    </div>
  </div>
  <div class="col-md-8">
    <div class="card p-4">
      <h5 class="fw-bold mb-4">Account Information</h5>
      <div class="row mb-3">
        <div class="col-md-4 text-muted fw-semibold">Full Name</div>
        <div class="col-md-8 fw-semibold"><%= user.name %></div>
      </div>
      <hr>
      <div class="row mb-3">
        <div class="col-md-4 text-muted fw-semibold">Role</div>
        <div class="col-md-8"><span class="badge bg-primary"><%= user.role %></span></div>
      </div>
      <hr>
      <div class="row mb-3">
        <div class="col-md-4 text-muted fw-semibold">Account ID</div>
        <div class="col-md-8"><code><%= user.id %></code></div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>